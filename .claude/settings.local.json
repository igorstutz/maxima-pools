      "Bash(ls src/app/pool-accessories-and-extras/ src/content/pages/pool-accessories*.json)",
      "Bash(ls src/app/outdoor-living/ src/content/pages/outdoor-living.json)",
      "PowerShell(Get-Process *)",
      "PowerShell(npx tsc --noEmit 2>&1 | Select-Object -First 20; if \\($LASTEXITCODE -eq 0 -or $null -eq $LASTEXITCODE\\) { \"TYPECHECK OK\" })",
      "PowerShell(npx tsc --noEmit 2>&1 | Select-Object -First 15; if \\($LASTEXITCODE -eq 0 -or $null -eq $LASTEXITCODE\\) { \"TYPECHECK OK\" })"
    ]
  }
}
